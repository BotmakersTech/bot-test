# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=botleague
POSTGRES_USER=botleague_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ── JWT ────────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX_STRING

# ── Mail (Gmail SMTP) ──────────────────────────────────────────────────────────
MAIL_USERNAME=CHANGE_ME_GMAIL_ADDRESS
MAIL_PASSWORD=CHANGE_ME_GMAIL_APP_PASSWORD

# ── MSG91 (OTP provider) ───────────────────────────────────────────────────────
MSG91_AUTH_KEY=CHANGE_ME_MSG91_AUTH_KEY
MSG91_TEMPLATE_ID=CHANGE_ME_MSG91_TEMPLATE_ID

# ── App URLs ───────────────────────────────────────────────────────────────────
FRONTEND_URL=https://test.botleague.in
VITE_API_URL=https://api.botleague.in/api

# ── Cloudflare R2 (object storage) ────────────────────────────────────────────
R2_ACCOUNT_ID=CHANGE_ME_R2_ACCOUNT_ID
R2_ACCESS_KEY=CHANGE_ME_R2_ACCESS_KEY
R2_SECRET_KEY=CHANGE_ME_R2_SECRET_KEY
R2_BUCKET=botleague-assets
R2_PUBLIC_URL=https://media.botleague.in
